# Production (SaaS) — baked into the static export at `next build` time
# (i.e. when you run `npm run dist:win`). Overrides .env for production builds.
#
# The Electron client ships as a PURE FRONTEND and connects to this central
# cloud backend. NO secrets belong here — the cloud server alone holds the
# OpenAI / Azure credentials. Replace the placeholder with your real HTTPS URL.
NEXT_PUBLIC_API_URL=https://api.your-domain.com
